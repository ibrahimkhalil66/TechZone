@model IEnumerable<Ecom1.Models.Order>

@{
    ViewData["Title"] = "Admin Orders";
}

<h1 class="mb-4">Orders Management</h1>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Order ID</th>
            <th>Customer</th>
            <th>Phone</th>
            <th>Total</th>
            <th>Date</th>
            <th>Details</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>#@order.Id</td>
                <td>@order.FullName</td>
                <td>@order.Phone</td>
                <td>@order.TotalPrice DA</td>
                <td>@order.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    <a asp-action="Details"
                           asp-route-id="@order.Id"
                           class="btn btn-primary btn-sm">
                        View
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>