@model IEnumerable<Ecom1.Models.Product>

@{
    ViewData["Title"] = "Tech Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold">Tech Store</h1>
        <p class="text-muted">Discover laptops, phones, and accessories</p>
    </div>

   
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-0">

                <a asp-action="Details" asp-route-id="@item.IdProduct">
                        
                
                @if (!string.IsNullOrEmpty(item.ImageUrl))
                {
                    <img src="@item.ImageUrl"
                         class="card-img-top"
                         style="height:250px; object-fit:cover;"
                         alt="@item.NameProduct" />
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center"
                         style="height:250px;">
                        <span class="text-muted">No Image</span>
                    </div>
                }

                </a>

                <div class="card-body">
                    <h5 class="card-title fw-bold">
                        @item.NameProduct
                    </h5>

                    <p class="card-text text-muted">
                        @item.Description
                    </p>

                    <p class="mb-1">
                        <strong>Quantity:</strong> @item.Quantity
                    </p>

                    <h4 class="text-primary fw-bold">
                        @item.PriceProduct DA
                    </h4>
                </div>

                <div class="card-footer bg-white border-0 d-flex gap-2">
                    
                    <a asp-controller="Cart"
                           asp-action="AddToCart"
                           asp-route-id="@item.IdProduct"
                           class="btn btn-success btn-sm">
                        Add To Cart
                    </a>
                </div>
            </div>
        </div>
    }
</div>