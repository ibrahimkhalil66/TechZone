@model IEnumerable<Ecom1.Models.Product>

@{
    ViewData["Title"] = "Tech Products Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold">Tech Store Management</h1>
        <p class="text-muted">Manage all your products</p>
    </div>

    <a asp-action="Create" class="btn btn-dark rounded-pill px-4">
        + Add Product
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">

        <table class="table align-middle mb-0">

            <thead class="table-light">
                <tr>
                    <th>Product</th>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Description</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <!-- Product Image -->
                        <td style="width:100px;">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl"
                                     alt="@item.NameProduct"
                                     class="rounded shadow-sm"
                                     style="width:70px; height:70px; object-fit:cover;" />
                            }
                            else
                            {
                                <div class="bg-light rounded d-flex align-items-center justify-content-center"
                                     style="width:70px; height:70px;">
                                    <small class="text-muted">No Img</small>
                                </div>
                            }
                        </td>

                        <!-- Name -->
                        <td class="fw-semibold">
                            @item.NameProduct
                        </td>

                        <!-- Price -->
                        <td class="text-primary fw-bold">
                            @item.PriceProduct DA
                        </td>

                        <!-- Quantity -->
                        <td>
                            @item.Quantity
                        </td>

                        <!-- Description -->
                        <td class="text-muted">
                            @(item.Description != null && item.Description.Length > 50
                                ? item.Description.Substring(0, 50) + "..."
                                : item.Description)
                        </td>

                        <!-- Actions -->
                        <td>
                            <div class="d-flex justify-content-center gap-2">

                                <a asp-action="Details"
                                       asp-route-id="@item.IdProduct"
                                       class="btn btn-outline-primary btn-sm rounded-pill">
                                    Details
                                </a>

                                <a asp-action="Edit"
                                       asp-route-id="@item.IdProduct"
                                       class="btn btn-outline-warning btn-sm rounded-pill">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                       asp-route-id="@item.IdProduct"
                                       class="btn btn-outline-danger btn-sm rounded-pill">
                                    Delete
                                </a>

                            </div>
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>
</div>